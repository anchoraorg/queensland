`,y=p.Ay.div`
  width: 100%;
  display: flex;
  gap: 14px;
  align-items: center;

  [type="button"] {
    display: inline-flex;
    align-items: center;
    height: 32px;
    gap: 8px;
    padding: 2px;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    justify-content: center;
    flex: 1 1 calc((100% - 14px) / 2);
    transition: transform 0.2s ease;
    letter-spacing: 0.0525rem;
    font-size: ${e=>e.theme.global.font.size.small};
    line-height: ${e=>e.theme.global.font.lineHeight.normal};
    font-weight: ${e=>e.theme.global.font.weight.bold};
    color: ${c.V8.TEAL_2};
    &:hover {
      background-color: ${c.V8.TEAL_2};
      color: ${c.V8.WHITE};
