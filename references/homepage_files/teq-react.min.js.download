  position: relative;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  height: 100%;
  cursor: pointer;
  border-radius: ${e=>e.setMapBorderRadius?"10px":0};
  margin-left: 5px;

  .mapboxgl-map {
    height: 100%;
  }

  .mapboxgl-canvas {
    position: absolute;
    top: 0;
    left: 0;
  }

  .mapboxgl-marker {
    position: absolute;
    transform: translate(-50%, -100%);
    z-index: 1;
  }

  .mapboxgl-popup {
    z-index: 2;
    pointer-events: auto;
  }

  .mapboxgl-popup-content {
    background: ${o.V8.WHITE};
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(68, 44, 44, 0.25);
    max-width: 350px;
    height: auto;
    min-height: 200px;
  }

  .mapboxgl-popup.mapboxgl-popup-anchor-bottom .mapboxgl-popup-content {
    min-height: 200px;
  }

  .mapboxgl-popup-tip {
    border-top-color: #d16a6aff;
  }
  .mapboxgl-popup-close-button {
    display: none;
  }

  .mapboxgl-ctrl-bottom-right {
    display: flex;
    align-items: flex-end;
    padding: 0 10px 8px 10px;
  }

  .mapboxgl-ctrl-bottom-right .mapboxgl-ctrl-scale {
    background: transparent;
    border: none;
    font-size: 13px;
    color: ${o.V8.BLACK};
    text-align: center;
  }

  .mapboxgl-ctrl-bottom-right .mapboxgl-ctrl-scale::after {
    content: "";
    display: block;
    height: 3px;
    width: 100%;
    background: ${o.V8.BLACK};
    margin-top: 3px;
  }

  @media (max-width: ${o.Rp.LG}px) {
    margin: 0;
