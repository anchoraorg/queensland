  width: 100%;
  position: relative;
  height: 60px;
  display: flex;
  align-items: center;
  background: ${e=>{let{isTransparent:t}=e;return t?(0,T.No)(.7,u.V8.BLACK):u.V8.WHITE}};
  transition: color 0.35s, background-color 0.35s;

  @media (min-width: ${u.Rp.XL}px) {
    padding: 0 30px;
  }

  .swiper-container {
    width: 100%;
    height: 100%;

    & > .swiper-scrollbar {
      bottom: 5px;
      height: 3px;
      background: none;
    }
  }

  .swiper-scrollbar-drag {
    background-color: ${e=>{let{isTransparent:t}=e;return t?(0,T.No)(.4,u.V8.BLACK):u.V8.SLATE}};
  }
  
  .swiper-wrapper {
    width: calc(100% - 60px);
  }

  .menu-container {
    display: flex;
  }

  .menu-item {
    margin: 0 10px;
    font-family: ${e=>e.theme.global.font.family.primary};
    font-size: 14px;
    font-weight: ${u.Wo.BOOK};
    width: auto;
    white-space: nowrap;
    display: inline-flex;

    &:last-child {
      margin-right: 45px;
    }

    &.menu-item-style {
      border-radius: 0;
      padding: 0;
      box-shadow: 0 16px 16px 0 rgba(57, 57, 57, 0.5);

      &.button {
        text-shadow: rgba(0, 0, 0, 0.7) 0px 2px 10px;
      }
    }
  }

  .swiper-button {
    &-prev,
    &-next {
      width: 30px;
      height: 30px;
      background: ${e=>{let{isTransparent:t}=e;return t?(0,T.No)(.4,u.V8.BLACK):u.V8.SLATE}};
      margin-top: -15px;
      left: 0;
