`,gy=p.Ay.div`
  position: relative;
  height: calc(50%);
  pointer-events: auto;
  flex-basis: 50%;
  flex-grow: 0;
  flex-shrink: 0;

  .swiper-container {
    width: 100%;
    height: 100%;
  }

  .swiper-slide {
    flex-shrink: 0;
    height: 100%;
  }

  .swiper-slide > * {
    width: 100%;
    height: 100%;
    display: block;
  }

  .swiper-wrapper {
    display: flex;
    flex-direction: row;
    height: 100%;
  }

  .swiper-pagination {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    text-align: center;
  }

  .swiper-pagination-bullet {
    display: inline-block;
    width: 10px;
    height: 10px;
    margin: 0 4px;
    background: ${u.V8.GREY};
    opacity: 0.6;
    border-radius: 50%;
  }

  .swiper-pagination-bullet-active {
    display: inline-block;
    background: ${u.V8.WHITE};
    border: 0.5px solid ${u.V8.BLACK};
    opacity: 1;
  }

  .overlay {
    position: absolute;
    z-index: 3;
    top: 16px;
    right: 16px;
    display: inline-flex;
    align-items: center;
    border-radius: 5px;
    overflow: hidden;
    text-transform: uppercase;
    font-size: ${e=>e.theme.global.font.size.xxlarge};
    line-height: ${e=>e.theme.global.font.lineHeight.high};
    font-weight: ${e=>e.theme.global.font.weight.bold};
  }

  .info-button {
    position: absolute;
    z-index: 2;
    bottom: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 17px;
    height: 17px;

    &:hover {
      transform: scale(1.1);
    }
    &:hover + .image-tooltip,
    &:focus-within + .image-tooltip {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  .tag {
    position: absolute;
    z-index: 3;
    bottom: -12px;
    left: 14px;
    span {
      border-radius: 5px;
    }
  }

  .blurry-background {
    position: absolute;
    height: calc(70%);
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    display: inline-block;
    background: linear-gradient(
      to top,
      ${u.V8.BLACK}26 0%,
      ${u.V8.BLACK}00 100%
    );
    padding: 12px 16px;
    pointer-events: none;
  }
