        ${e=>{let{isTransparent:t}=e;return t?"transparent":u.V8.WHITE}};
      transition: box-shadow 0.35s;
      &:after {
        font-size: 10px;
        color: ${u.V8.WHITE};
      }
    }
    &-next {
      left: initial;
      right: 0;
    }
    &-disabled {
      display: none;
    }
  }


  .rc-menu {
    &-button {
      font-weight: ${u.Wo.MEDIUM};
      color: ${e=>{let{colour:t}=e;return t}};
      padding: 7px 10px;
      display: flex;
      align-items: center;
      text-decoration: none;
      & > span {
        margin-left: 3px;
        transform: rotate(90deg);
        svg {
          color: ${e=>{let{colour:t}=e;return t}};
        }
      }
      &--open {
        color: ${e=>{let{colour:t}=e;return t}};
        background: ${e=>{let{isTransparent:t}=e;return t?(0,T.No)(.8,u.V8.WHITE):(0,T.uq)(.9,u.V8.SLATE)}};
        & > span {
          transform: rotate(-90deg);
        }
      }
    }
  }

  .rc-menu-item {
  
    &:hover {
      background: rgba(0, 128, 128, 0.1); /* or use tint function in preprocessor */
      color: var(--dark-teal);
      outline: -webkit-focus-ring-color auto 1px;
    }
  }
