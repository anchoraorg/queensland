`,m=p.Ay.div`
  flex: 0 0 50%;
  width: 50%;
  position: relative;

  flex: 0 0 auto;
  height: 130px;
  width: 100%;

  img {
    border-radius: 8px 8px 0 0;
  }

  .tag {
    position: absolute;
    left: 16px;
    bottom: -16px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    overflow: hidden;
    text-transform: uppercase;
    font-size: ${e=>e.theme.global.font.size.tiny};
    line-height: ${e=>e.theme.global.font.lineHeight.normal};
    font-weight: ${e=>e.theme.global.font.weight.medium};
  }

  .feature-deals-tag {
    position: absolute;
    left: 16px;
    top: 16px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    overflow: hidden;
    text-transform: uppercase;
    font-size: ${e=>e.theme.global.font.size.tiny};
    line-height: ${e=>e.theme.global.font.lineHeight.normal};
    font-weight: ${e=>e.theme.global.font.weight.medium};
    span {
      background: ${c.V8.RED};
    }
  }

  .favourite {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .boqeLogo {
    text-align: center;
    max-width: 60px;
    position: absolute;
    right: 16px;
    bottom: -20px;
  }
`,v=p.Ay.div`
  margin-bottom: auto;
  text-align: left;
  background-color: ${c.V8.TRANSPARENT};

  h5 {
    text-transform: uppercase;
    letter-spacing: 0.0175rem;
    font-size: ${e=>e.theme.global.font.size.small};
    line-height: ${e=>e.theme.global.font.lineHeight.high};
    font-weight: ${e=>e.theme.global.font.weight.bold};
    color: ${e=>e.active?`${c.V8.TEAL_DEEP}`:`${c.V8.CHARCOAL}`};
    margin: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    text-overflow: ellipsis;
    overflow: hidden;
    -webkit-line-clamp: 1;
  }

  p {
    font-size: ${e=>e.theme.global.font.size.tiny};
    font-weight: ${e=>e.theme.global.font.weight.normal};
    color: ${e=>e.active?`${c.V8.TEAL_DEEP}`:`${c.V8.GREY_CHARCOAL}`};
    white-space: pre-line;
    letter-spacing: 0;
    margin: 10px 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    text-overflow: ellipsis;
    line-height: 2;
  }

  b {
    color: ${c.V8.TEAL};
  }
`,g=p.Ay.div`
  display: inline-flex;
  align-items: flex-start;
  gap: 10px;
  span {
    padding-top: 5px;
  }

