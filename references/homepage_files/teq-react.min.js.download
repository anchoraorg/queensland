  ${nN}

  html,
  body {
    color: ${e=>e.theme.global.font.colour.dark};
    font-family: ${e=>e.theme.global.font.family.primary};
    scroll-behavior: smooth;
    font-size: 1rem;
    line-height: 1.5;

    // Mobile Search Modal Style for the header menu v2
    &.modal-active .modal-wrapper {
      top: 91px;

      @media (min-width: ${u.Rp.MD_LG}px) {
        top: 0;
      }
    }
  }

  body {
    overflow-x: hidden;
  }

  * {
    box-sizing: border-box;
    -webkit-appearance: none;
  }

  figure {
    margin: 0;
    padding: 0;
  }

  h1 {
    font-family: ${e=>e.theme.global.font.family.mainHeadings};
    letter-spacing: .1rem;
  }
  h2 {
    font-family: ${e=>e.theme.global.font.family.mainHeadings};
    letter-spacing: .1rem;
  }
  h3,
  h4,
  h5,
  h6 {
    font-family: ${e=>e.theme.global.font.family.secondary};
    letter-spacing: .1rem;
  }

  #page {
    max-width: ${u.Rp.XL}px;
    margin: 0 auto;
  }

  button {
    padding: 0;
    -webkit-appearance: none;
    cursor: pointer;
    background: none;
    border: 0;
  }

  .grecaptcha-badge { visibility: hidden; }

  a {
    color: inherit;
  }
